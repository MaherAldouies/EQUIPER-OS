APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# EQUIPER OS — Salla Anti-Corruption Layer (F3)
SALLA_API_BASE_URL=https://api.salla.dev/admin/v2
SALLA_TOKEN_URL=https://accounts.salla.sa/oauth2/token
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_WEBHOOK_SECRET=
SALLA_ACCESS_TOKEN=
SALLA_REFRESH_TOKEN=

# EQUIPER OS — AI Reasoning Service (F6)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

REDIS_EVENT_STREAM=equiper:events

# EQUIPER OS — Social Media Hub: WhatsApp Business Cloud API
WHATSAPP_API_BASE_URL=https://graph.facebook.com/v23.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# EQUIPER OS — Social Media Hub: Meta Graph API (Instagram + Facebook)
META_API_BASE_URL=https://graph.facebook.com/v23.0
META_IG_USER_ID=
META_PAGE_ID=
META_ACCESS_TOKEN=
META_VERIFY_TOKEN=
META_APP_SECRET=

# EQUIPER OS — Social Media Hub: TikTok Content Posting API (publish-only)
TIKTOK_API_BASE_URL=https://open.tiktokapis.com/v2
TIKTOK_ACCESS_TOKEN=
TIKTOK_PRIVACY_LEVEL=PUBLIC_TO_EVERYONE

# EQUIPER OS — Social Media Hub: X (Twitter) API v2
# COST WARNING: no free tier — every publish/mentions-poll bills the account.
X_API_BASE_URL=https://api.x.com/2
X_TOKEN_URL=https://api.x.com/2/oauth2/token
X_CLIENT_ID=
X_USER_ID=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
X_MENTIONS_POLL_INTERVAL_MINUTES=30
